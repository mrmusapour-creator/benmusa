{
  "name": "Ben Musa",
  "short_name": "Ben Musa",
  "description": "Premium Hajj and Umrah travel product platform.",
  "start_url": "/benmusa/",
  "scope": "/benmusa/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#FFFFFF",
  "theme_color": "#0D6E6E",
  "categories": ["travel", "shopping", "lifestyle"],
  "lang": "fa",
  "dir": "rtl",
  "icons": [
    {
      "src": "/benmusa/icons/icon.svg",
      "sizes": "any",
